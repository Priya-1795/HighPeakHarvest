<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Login - High Peak Harvest</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --green-deep: #1B3A27;
  --gold: #C9A84C;
  --cream: #F5F0E6;
  --text-dark: #1C1C1A;
  --sans: 'Jost', sans-serif;
}

body {
  font-family: var(--sans);
  background: var(--green-deep);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.login-container {
  background: var(--cream);
  padding: 3rem;
  border-radius: 2px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.1);
  max-width: 360px;
  width: 100%;
}

.login-container h1 {
  font-size: 1.8rem;
  margin-bottom: 0.5rem;
  color: var(--text-dark);
}

.login-container p {
  color: #7A7568;
  margin-bottom: 2rem;
  font-size: 0.9rem;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  margin-bottom: 0.5rem;
  font-weight: 500;
  color: var(--text-dark);
  font-size: 0.9rem;
}

.form-group input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid #D4C9B0;
  border-radius: 2px;
  font-family: var(--sans);
  font-size: 0.95rem;
}

.form-group input:focus {
  outline: none;
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
}

button {
  width: 100%;
  padding: 0.75rem;
  background: var(--gold);
  color: var(--green-deep);
  border: none;
  border-radius: 2px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  font-size: 0.95rem;
  letter-spacing: 0.05em;
}

button:hover {
  background: #E2C97A;
}

.error-message {
  background: #ffebee;
  color: #c62828;
  padding: 0.75rem 1rem;
  border-radius: 2px;
  margin-bottom: 1.5rem;
  font-size: 0.9rem;
  border-left: 3px solid #c62828;
}

.back-link {
  display: block;
  text-align: center;
  margin-top: 1.5rem;
  color: var(--gold);
  text-decoration: none;
  font-size: 0.9rem;
}

.back-link:hover {
  text-decoration: underline;
}

.default-creds {
  background: #f5f5f5;
  padding: 1rem;
  border-radius: 2px;
  margin-top: 2rem;
  font-size: 0.8rem;
  color: #666;
}

.default-creds p {
  margin: 0.3rem 0;
}
</style>
</head>
<body>

<div class="login-container">
  <h1>Admin Login</h1>
  <p>High Peak Harvest</p>
  
  <% if (error) { %>
    <div class="error-message"><%= error %></div>
  <% } %>
  
  <form method="POST">
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" placeholder="admin@highpeakharvest.co.uk" required autofocus>
    </div>
    
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="••••••••" required>
    </div>
    
    <button type="submit">Sign in</button>
  </form>
  
  <div class="default-creds">
    <p><strong>Default credentials:</strong></p>
    <p>Email: admin@highpeakharvest.co.uk</p>
    <p>Password: admin123</p>
    <p style="margin-top: 0.5rem; color: #999;">Change these immediately!</p>
  </div>
  
  <a href="/" class="back-link">← Back to homepage</a>
</div>

</body>
</html>
