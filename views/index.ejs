            <option>Café / Coffee shop</option>
            <option>Greengrocer / Farm shop</option>
            <option>Pub / Bar</option>
            <option>Hotel / Hospitality</option>
            <option>Other trade</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Town / area</label>
          <input type="text" name="town" class="form-input" placeholder="Glossop" required>
        </div>
      </div>

      <button type="button" class="btn-form" id="submitBtn" onclick="submitForm(event)">Send me the list</button>

