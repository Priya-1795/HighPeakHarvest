<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>High Peak Harvest — Microgreens & Mushrooms, Glossop</title>
<style>
  :root {
    --img-market: url("data:image/jpeg;base64,");
    --img-micro-tray: url("data:image/jpeg;base64,");
    --img-micro-life: url("data:image/jpeg;base64,");
    --img-fresh-mush: url("data:image/jpeg;base64,");
    --img-smoked-mush: url("data:image/jpeg;base64,");
    --img-smoked-garlic: url("data:image/jpeg;base64,");
    --img-smoked-salt: url("data:image/jpeg;base64,");
    --img-jerky: url("data:image/jpeg;base64,");
    --img-sprouting: url("data:image/jpeg;base64,");
    --img-van: url("data:image/jpeg;base64,");
    --img-logo: url("data:image/jpeg;base64,");
  }
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-deep: #1B3A27;
    --green-mid: #2D5A3D;
    --green-light: #3D7A52;
    --gold: #C9A84C;
    --gold-light: #E2C97A;
    --gold-pale: #F0DFA0;
    --cream: #F5F0E6;
    --cream-warm: #EDE5D4;
    --cream-dark: #D4C9B0;
    --text-dark: #1C1C1A;
    --text-mid: #3D3D38;
    --text-muted: #7A7568;
    --white: #FDFAF4;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Jost', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--cream);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 4rem;
    background: rgba(27, 58, 39, 0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }

  .nav-logo {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--gold-light);
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .nav-logo span { color: var(--gold-pale); font-weight: 300; font-style: italic; }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--gold-light); }

  .nav-cta {
    background: var(--gold);
    color: var(--green-deep) !important;
    padding: 0.55rem 1.4rem;
    border-radius: 2px;
    font-weight: 600 !important;
    letter-spacing: 0.1em !important;
    transition: background 0.2s, transform 0.15s !important;
  }

  .nav-cta:hover { background: var(--gold-light) !important; transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: var(--green-deep);
    background-image: var(--img-market);
    background-size: cover;
    background-position: center top;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 8rem 4rem 5rem;
  }

  .hero-bg-texture {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(15,35,25,0.92) 0%, rgba(15,35,25,0.75) 55%, rgba(15,35,25,0.45) 100%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(201,168,76,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.8rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.2s forwards;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }

  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 400;
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 1.8rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.35s forwards;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-sub {
    font-size: 1.05rem;
    font-weight: 300;
    color: rgba(253,250,244,0.72);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 2.8rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.5s forwards;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s 0.65s forwards;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2rem;
    background: var(--gold);
    color: var(--green-deep);
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(201,168,76,0.3);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2rem;
    background: transparent;
    color: rgba(253,250,244,0.85);
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    border: 1px solid rgba(253,250,244,0.3);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    cursor: pointer;
  }

  .btn-secondary:hover {
    border-color: var(--gold);
    color: var(--gold-light);
    background: rgba(201,168,76,0.06);
  }

  .hero-badges {
    position: absolute;
    right: 4rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    z-index: 2;
    opacity: 0;
    animation: fadeLeft 0.9s 0.8s forwards;
  }

  .hero-badge {
    background: rgba(27,58,39,0.8);
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 4px;
    padding: 1.2rem 1.5rem;
    text-align: center;
    min-width: 160px;
    backdrop-filter: blur(4px);
  }

  .hero-badge-num {
    font-family: var(--serif);
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--gold-light);
    line-height: 1;
    display: block;
  }

  .hero-badge-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(253,250,244,0.6);
    margin-top: 0.3rem;
    display: block;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: rgba(253,250,244,0.4);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: scrollBounce 2s infinite;
  }

  .hero-scroll::after {
    content: '';
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(201,168,76,0.5), transparent);
  }

  /* ── SECTION UTILITIES ── */
  section { padding: 6rem 4rem; }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 1rem;
  }

  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  .section-headline {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--green-deep);
    margin-bottom: 1.2rem;
  }

  .section-headline em { font-style: italic; color: var(--green-light); }

  .section-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-muted);
    max-width: 540px;
    line-height: 1.8;
  }

  .divider {
    width: 60px;
    height: 2px;
    background: linear-gradient(to right, var(--gold), transparent);
    margin: 1.5rem 0;
  }

  /* ── TRUST BAR ── */
  .trust-bar {
    background: var(--cream-warm);
    border-top: 1px solid var(--cream-dark);
    border-bottom: 1px solid var(--cream-dark);
    padding: 1.5rem 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-mid);
  }

  .trust-icon {
    width: 18px;
    height: 18px;
    color: var(--gold);
  }

  /* ── PRODUCTS ── */
  .products-section {
    background: var(--white);
  }

  .products-header {
    max-width: 1300px;
    margin: 0 auto 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .products-grid {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .product-card {
    position: relative;
    overflow: hidden;
    background: var(--cream);
    aspect-ratio: 4/5;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    cursor: pointer;
  }

  .product-card:hover .product-img-wrap { transform: scale(1.04); }
  .product-card:hover .product-overlay { background: rgba(27,58,39,0.72); }

  .product-img-wrap {
    position: absolute;
    inset: 0;
    transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
  }

  .product-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0;
  }

  /* Coloured product backgrounds */
  .pc-1 { background: linear-gradient(145deg, #2d5a3d 0%, #1b3a27 100%); }
  .pc-2 { background: linear-gradient(145deg, #3d4a30 0%, #252f1e 100%); }
  .pc-3 { background: linear-gradient(145deg, #4a3820 0%, #2e2210 100%); }
  .pc-4 { background: linear-gradient(145deg, #4a3820 0%, #2e2210 100%); }
  .pc-5 { background: linear-gradient(145deg, #3a3a2a 0%, #252518 100%); }
  .pc-6 { background: linear-gradient(145deg, #1d3a2e 0%, #0e2219 100%); }

  .product-overlay {
    position: absolute;
    inset: 0;
    background: rgba(27,58,39,0.55);
    transition: background 0.4s;
  }

  .product-info {
    position: relative;
    z-index: 2;
    padding: 2rem;
  }

  .product-tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-light);
    border: 1px solid rgba(201,168,76,0.4);
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
    margin-bottom: 0.7rem;
  }

  .product-name {
    font-family: var(--serif);
    font-size: 1.7rem;
    font-weight: 400;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .product-desc {
    font-size: 0.82rem;
    font-weight: 300;
    color: rgba(253,250,244,0.75);
    line-height: 1.6;
  }

  .product-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 2;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-light);
    font-size: 1rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s, transform 0.3s;
  }

  .product-card:hover .product-arrow { opacity: 1; transform: translateY(0); }

  /* Large featured card */
  .product-card-large {
    grid-column: span 2;
    aspect-ratio: 8/5;
  }

  /* ── WHY US ── */
  .why-section {
    background: var(--green-deep);
    position: relative;
    overflow: hidden;
  }

  .why-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 80% at 80% 50%, rgba(45,90,61,0.5), transparent);
    pointer-events: none;
  }

  .why-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .why-left .section-eyebrow { color: var(--gold); }
  .why-left .section-headline { color: var(--white); }
  .why-left .section-sub { color: rgba(253,250,244,0.65); max-width: 100%; }

  .why-features {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .why-feature {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(201,168,76,0.12);
  }

  .why-feature:last-child { border-bottom: none; padding-bottom: 0; }

  .why-num {
    font-family: var(--serif);
    font-size: 2.5rem;
    font-weight: 300;
    color: rgba(201,168,76,0.25);
    line-height: 1;
    min-width: 48px;
  }

  .why-feature-body {}

  .why-feature-title {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.4rem;
  }

  .why-feature-text {
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(253,250,244,0.6);
    line-height: 1.75;
  }

  /* ── TRADE SECTION ── */
  .trade-section {
    background: var(--cream-warm);
    padding: 6rem 4rem;
  }

  .trade-inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .trade-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
    align-items: end;
  }

  .trade-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .trade-card {
    background: var(--white);
    border: 1px solid rgba(27,58,39,0.1);
    border-radius: 4px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .trade-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--gold), var(--gold-pale));
  }

  .trade-card-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .trade-card-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--green-deep);
    margin-bottom: 0.6rem;
  }

  .trade-card-text {
    font-size: 0.87rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .delivery-days {
    margin-top: 1.2rem;
    display: flex;
    gap: 0.5rem;
  }

  .day-pill {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-deep);
    background: rgba(27,58,39,0.08);
    border: 1px solid rgba(27,58,39,0.15);
    padding: 0.3rem 0.8rem;
    border-radius: 2px;
  }

  /* ── AVAILABILITY ── */
  .availability-section {
    background: var(--white);
    padding: 6rem 4rem;
  }

  .availability-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 6rem;
    align-items: start;
  }

  .avail-list {
    border: 1px solid rgba(27,58,39,0.1);
    border-radius: 4px;
    overflow: hidden;
  }

  .avail-header-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1rem;
    padding: 0.9rem 1.5rem;
    background: var(--green-deep);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.85);
  }

  .avail-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid rgba(27,58,39,0.07);
    align-items: center;
    transition: background 0.2s;
  }

  .avail-row:last-child { border-bottom: none; }
  .avail-row:hover { background: rgba(27,58,39,0.03); }

  .avail-name {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--green-deep);
  }

  .avail-cat {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
  }

  .avail-size {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--text-muted);
    text-align: right;
  }

  .avail-status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .avail-status.in { color: #2D7A3D; }
  .avail-status.limited { color: #C9A84C; }
  .avail-status.out { color: #A0503A; }

  .avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .avail-status.in .avail-dot { background: #2D7A3D; }
  .avail-status.limited .avail-dot { background: #C9A84C; }
  .avail-status.out .avail-dot { background: #A0503A; }

  /* ── SIGNUP FORM ── */
  .signup-panel {
    background: var(--green-deep);
    border-radius: 4px;
    padding: 3rem;
    position: sticky;
    top: 6rem;
  }

  .signup-panel .section-eyebrow { color: var(--gold); }

  .signup-headline {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 0.8rem;
  }

  .signup-sub {
    font-size: 0.88rem;
    font-weight: 300;
    color: rgba(253,250,244,0.6);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .form-group { margin-bottom: 1rem; }

  .form-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(253,250,244,0.55);
    margin-bottom: 0.5rem;
  }

  .form-input {
    width: 100%;
    padding: 0.85rem 1.1rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 2px;
    color: var(--white);
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .form-input::placeholder { color: rgba(253,250,244,0.3); }
  .form-input:focus { border-color: var(--gold); background: rgba(255,255,255,0.1); }

  .form-select {
    width: 100%;
    padding: 0.85rem 1.1rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 2px;
    color: rgba(253,250,244,0.7);
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 300;
    outline: none;
    appearance: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .form-select:focus { border-color: var(--gold); }
  .form-select option { background: var(--green-deep); }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .btn-form {
    width: 100%;
    padding: 1rem;
    margin-top: 0.5rem;
    background: var(--gold);
    color: var(--green-deep);
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-form:hover { background: var(--gold-light); transform: translateY(-1px); }

  .or-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.2rem 0;
    color: rgba(253,250,244,0.3);
    font-size: 0.75rem;
  }

  .or-divider::before, .or-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(201,168,76,0.15);
  }

  .btn-wa {
    width: 100%;
    padding: 0.9rem;
    background: transparent;
    color: rgba(253,250,244,0.8);
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 2px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .btn-wa:hover { border-color: var(--gold); color: var(--gold-light); }

  /* ── DELIVERY AREA ── */
  .delivery-section {
    background: var(--cream);
    padding: 6rem 4rem;
  }

  .delivery-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .map-placeholder {
    background: var(--green-deep);
    border-radius: 4px;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(201,168,76,0.15);
  }

  .map-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 55% 45%, rgba(45,90,61,0.7) 0%, transparent 60%),
      radial-gradient(circle at 30% 70%, rgba(201,168,76,0.1) 0%, transparent 40%);
  }

  .map-label {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--gold-light);
    position: relative;
    z-index: 1;
  }

  .map-sub {
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(253,250,244,0.5);
    position: relative;
    z-index: 1;
  }

  /* Map dots */
  .map-dots {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .map-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--gold);
    border-radius: 50%;
    border: 2px solid rgba(201,168,76,0.4);
  }

  .map-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(201,168,76,0.15);
    animation: pulse 2s infinite;
  }

  .map-dot-label {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.8);
    white-space: nowrap;
  }

  .delivery-towns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.8rem;
  }

  .town-chip {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--text-mid);
    background: var(--cream-warm);
    border: 1px solid var(--cream-dark);
    padding: 0.35rem 0.9rem;
    border-radius: 2px;
    transition: background 0.2s, border-color 0.2s;
  }

  .town-chip:hover { background: var(--cream-dark); border-color: var(--gold); }
  .town-chip.main { font-weight: 600; color: var(--green-deep); border-color: rgba(27,58,39,0.2); }

  /* ── TESTIMONIALS ── */
  .testimonials-section {
    background: var(--green-deep);
    padding: 6rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .testimonials-section::before {
    content: '"';
    position: absolute;
    top: -2rem;
    left: 3rem;
    font-family: var(--serif);
    font-size: 20rem;
    font-weight: 300;
    color: rgba(201,168,76,0.05);
    line-height: 1;
    pointer-events: none;
  }

  .testimonials-inner {
    max-width: 1300px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .testimonials-header { margin-bottom: 3.5rem; }
  .testimonials-header .section-eyebrow { color: var(--gold); }
  .testimonials-header .section-headline { color: var(--white); }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 4px;
    padding: 2.5rem;
    position: relative;
  }

  .testimonial-card::before {
    content: '"';
    position: absolute;
    top: 1.2rem;
    right: 1.8rem;
    font-family: var(--serif);
    font-size: 3rem;
    color: rgba(201,168,76,0.2);
    line-height: 1;
  }

  .testimonial-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 1.2rem;
  }

  .star { color: var(--gold); font-size: 0.9rem; }

  .testimonial-text {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    color: rgba(253,250,244,0.85);
    line-height: 1.65;
    margin-bottom: 1.8rem;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(201,168,76,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--gold-light);
    flex-shrink: 0;
  }

  .author-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--white);
  }

  .author-role {
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(253,250,244,0.5);
    margin-top: 0.15rem;
  }

  /* ── FINAL CTA ── */
  .cta-section {
    background: var(--cream-warm);
    padding: 7rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 50% 0%, rgba(201,168,76,0.08), transparent);
  }

  .cta-inner {
    max-width: 680px;
    margin: 0 auto;
    position: relative;
  }

  .cta-headline {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: var(--green-deep);
    line-height: 1.1;
    margin-bottom: 1.2rem;
  }

  .cta-sub {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2rem;
    background: var(--green-deep);
    color: var(--gold-light);
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-dark:hover { background: var(--green-mid); transform: translateY(-2px); }

  .btn-outline-dark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2rem;
    background: transparent;
    color: var(--green-deep);
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    border: 1px solid rgba(27,58,39,0.3);
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-outline-dark:hover { border-color: var(--green-deep); background: rgba(27,58,39,0.06); }

  /* ── FOOTER ── */
  footer {
    background: #0F2319;
    padding: 4rem 4rem 2rem;
    border-top: 1px solid rgba(201,168,76,0.12);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand-name {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--gold-light);
    margin-bottom: 0.8rem;
  }

  .footer-brand-text {
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(253,250,244,0.45);
    line-height: 1.75;
    max-width: 280px;
  }

  .footer-col-title {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.2rem;
  }

  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }

  .footer-links a {
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(253,250,244,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--gold-light); }

  .footer-bottom {
    border-top: 1px solid rgba(201,168,76,0.08);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.78rem;
    font-weight: 300;
    color: rgba(253,250,244,0.3);
  }

  .footer-location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 400;
    color: rgba(201,168,76,0.6);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeLeft {
    from { opacity: 0; transform: translate(20px, -50%); }
    to { opacity: 1; transform: translate(0, -50%); }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(2); opacity: 0; }
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.75s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.75s cubic-bezier(0.25,0.46,0.45,0.94);
  }

  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* ──────────────────────────────────────────────────────────────────────────────────
     BASE - ENSURE ALL ELEMENTS RESPECT WIDTH CONSTRAINTS
     ────────────────────────────────────────────────────────────────────────────────── */

  * {
    box-sizing: border-box;
  }

  html, body {
    width: 100%;
    overflow-x: hidden;
  }

  /* ──────────────────────────────────────────────────────────────────────────────────
     RESPONSIVE DESIGN - TABLET (max-width: 1024px)
     ────────────────────────────────────────────────────────────────────────────────── */

  @media (max-width: 1024px) {
    /* Navigation */
    nav {
      padding: 0.9rem 2rem;
    }

    .nav-logo {
      font-size: 1.3rem;
    }

    .nav-links {
      gap: 1.5rem;
    }

    .nav-links a {
      font-size: 0.75rem;
    }

    /* Hero */
    .hero {
      padding: 7rem 2rem 3rem;
      min-height: 90vh;
    }

    .hero-headline {
      font-size: clamp(2.5rem, 5vw, 4rem);
    }

    .hero-sub {
      font-size: 0.95rem;
    }

    /* Sections */
    section {
      padding: 4rem 2rem;
    }

    .section-inner {
      max-width: 90%;
    }

    /* Grid layouts */
    .grid-2 {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }

    .grid-3 {
      grid-template-columns: 1fr 1fr !important;
      gap: 2rem !important;
    }

    /* Products Grid */
    .products-grid {
      grid-template-columns: 1fr 1fr !important;
      max-width: 100% !important;
      margin: 0 !important;
    }

    .products-header {
      max-width: 100% !important;
      flex-direction: column !important;
    }

    /* Why Grid */
    .why-grid {
      grid-template-columns: 1fr !important;
      max-width: 100% !important;
    }

    /* Forms */
    .form-input,
    .form-select,
    .form-label {
      font-size: 1rem;
    }
  }

  /* ──────────────────────────────────────────────────────────────────────────────────
     RESPONSIVE DESIGN - MOBILE (max-width: 768px)
     ────────────────────────────────────────────────────────────────────────────────── */

  @media (max-width: 768px) {
    /* General */
    body {
      font-size: 15px;
    }

    /* Navigation - Sticky & Compact */
    nav {
      padding: 0.75rem 1.2rem;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-size: 1.2rem;
    }

    .nav-links {
      display: none;
    }

    .nav-cta {
      padding: 0.45rem 0.9rem;
      font-size: 0.7rem;
      border-radius: 2px;
    }

    /* Hero Section */
    .hero {
      padding: 5.5rem 1.5rem 2.5rem;
      min-height: 85vh;
      background-position: center 30%;
    }

    .hero-content {
      max-width: 100%;
    }

    .hero-eyebrow {
      font-size: 0.65rem;
      margin-bottom: 1rem;
    }

    .hero-eyebrow::before {
      width: 24px;
    }

    .hero-headline {
      font-size: clamp(1.8rem, 6vw, 2.8rem);
      margin-bottom: 1rem;
      line-height: 1.15;
    }

    .hero-sub {
      font-size: 0.9rem;
      line-height: 1.6;
      margin-bottom: 1.8rem;
      max-width: 100%;
    }

    /* Buttons */
    .btn-primary,
    .btn-secondary,
    .btn-wa,
    .btn-form {
      padding: 0.65rem 1.2rem !important;
      font-size: 0.9rem !important;
      border-radius: 3px !important;
      width: 100% !important;
      text-align: center !important;
      margin-bottom: 0.8rem !important;
      display: block !important;
    }

    .btn-primary:hover,
    .btn-secondary:hover,
    .btn-wa:hover {
      transform: translateY(-2px);
    }

    /* Sections */
    section {
      padding: 2.5rem 1.5rem !important;
    }

    .section-inner {
      max-width: 100% !important;
      padding: 0 0.5rem !important;
      margin: 0 auto !important;
    }

    h2 {
      font-size: clamp(1.8rem, 5vw, 2.5rem);
      margin-bottom: 1.2rem;
    }

    h3 {
      font-size: 1.2rem;
      margin-bottom: 0.8rem;
    }

    /* Grid Layouts - Stack Vertically */
    .grid-2,
    .grid-3,
    .grid-4,
    .products-grid,
    .why-grid,
    .features-grid {
      grid-template-columns: 1fr !important;
      gap: 1.5rem !important;
      max-width: 100% !important;
      margin: 0 auto !important;
    }

    /* Products Grid - 2 columns on tablet */
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 1.2rem !important;
    }

    .products-header {
      max-width: 100% !important;
      flex-direction: column !important;
      align-items: flex-start !important;
    }

    /* Availability Section Layout */
    .availability-inner {
      display: flex !important;
      flex-direction: column !important;
      gap: 2rem !important;
    }

    .availability-table {
      width: 100% !important;
      max-width: 100% !important;
    }

    .signup-form {
      width: 100% !important;
      max-width: 100% !important;
    }

    /* Product Cards */
    .product-card {
      padding: 1.2rem;
    }

    .product-card h3 {
      font-size: 1.1rem;
    }

    /* Forms */
    .form-group {
      margin-bottom: 1.2rem;
    }

    .form-label {
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
      display: block !important;
    }

    .form-input,
    .form-select {
      padding: 0.75rem !important;
      font-size: 1rem !important;
      border-radius: 3px !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }

    .form-input::placeholder {
      font-size: 0.9rem;
    }

    /* Tables - Responsive */
    table {
      font-size: 0.85rem;
      width: 100% !important;
      display: table !important;
    }

    th, td {
      padding: 0.6rem 0.4rem;
      word-break: break-word;
    }

    /* Images */
    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    /* Features/Benefits Section */
    .feature-grid,
    .benefits-grid {
      grid-template-columns: 1fr !important;
      gap: 1.5rem !important;
    }

    .feature-item {
      padding: 1.2rem;
    }

    .feature-emoji {
      font-size: 2rem;
    }

    /* Footer */
    footer {
      padding: 2rem 1.5rem;
    }

    footer ul {
      flex-direction: column;
      gap: 1rem;
    }

    /* Spacing Utilities */
    .mt-1 { margin-top: 0.5rem !important; }
    .mb-1 { margin-bottom: 0.5rem !important; }
    .p-1 { padding: 0.75rem !important; }

    /* Dividers */
    .or-divider {
      margin: 1rem 0;
      font-size: 0.85rem;
    }

    /* Delivery Section */
    .delivery-towns {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .town-chip {
      font-size: 0.8rem;
      padding: 0.4rem 0.8rem;
    }
  }

  /* ──────────────────────────────────────────────────────────────────────────────────
     RESPONSIVE DESIGN - SMALL MOBILE (max-width: 480px)
     ────────────────────────────────────────────────────────────────────────────────── */

  @media (max-width: 480px) {
    /* General */
    body {
      font-size: 14px;
      width: 100vw;
      overflow-x: hidden;
    }

    html {
      overflow-x: hidden;
      width: 100%;
    }

    /* Navigation */
    nav {
      padding: 0.8rem 1rem;
      min-height: auto;
      overflow: visible !important;
      display: flex !important;
      align-items: center !important;
    }

    .nav-logo {
      font-size: 1.1rem;
      white-space: nowrap;
      overflow: visible !important;
      flex: 1 !important;
    }

    .nav-cta {
      padding: 0.4rem 0.75rem;
      font-size: 0.65rem;
    }

    /* Hero */
    .hero {
      padding: 6rem 1rem 2rem;
      min-height: 75vh;
      overflow: hidden;
      position: relative;
    }

    .hero-content {
      max-width: 100% !important;
      width: 100% !important;
      padding-right: 1rem;
    }

    .hero-headline {
      font-size: clamp(1.5rem, 5vw, 2.2rem);
      margin-bottom: 0.8rem;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .hero-eyebrow {
      font-size: 0.6rem;
      margin-bottom: 0.8rem;
    }

    .hero-sub {
      font-size: 0.85rem;
      margin-bottom: 1.5rem;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .hero-badges {
      display: none !important;
    }

    .hero-scroll {
      display: none !important;
    }

    .hero-bg-texture,
    .hero-grid-overlay {
      display: none !important;
    }

    .hero-ctas {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      width: 100%;
    }

    .btn-primary,
    .btn-secondary,
    .btn-wa,
    .btn-form {
      padding: 0.6rem 1rem !important;
      font-size: 0.85rem !important;
      width: 100% !important;
      display: block !important;
      text-align: center;
    }

    /* Override all max-widths for mobile */
    .cta-inner,
    .products-inner,
    .why-content,
    .availability-inner,
    .testimonials-inner,
    .content-wrapper {
      max-width: 100% !important;
      width: 100% !important;
      padding: 0 1rem !important;
    }

    /* Why section - stack on mobile */
    .why-inner {
      max-width: 100% !important;
      width: 100% !important;
      padding: 0 1rem !important;
      display: flex !important;
      flex-direction: column !important;
