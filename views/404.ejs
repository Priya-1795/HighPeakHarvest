<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Page Not Found</title>
<style>
* { box-sizing: border-box; }
body { 
  font-family: 'Jost', sans-serif;
  background: #F5F0E6;
  color: #1C1C1A;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  margin: 0;
  padding: 2rem;
}
.container {
  text-align: center;
  max-width: 500px;
}
h1 { font-size: 4rem; margin-bottom: 0.5rem; color: #1B3A27; }
p { font-size: 1.1rem; margin-bottom: 2rem; color: #666; }
a { 
  display: inline-block;
  background: #C9A84C;
  color: #1B3A27;
  padding: 0.75rem 2rem;
  text-decoration: none;
  border-radius: 2px;
  font-weight: 600;
}
a:hover { background: #E2C97A; }
</style>
</head>
<body>
<div class="container">
  <h1>404</h1>
  <p><%= message %></p>
  <a href="/">← Back to homepage</a>
</div>
</body>
</html>
