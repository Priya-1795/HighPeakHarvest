<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>High Peak Harvest — Microgreens & Mushrooms, Glossop</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --green-deep: #1B3A27;
  --green-mid: #2D5A3D;
  --green-light: #3D7A52;
  --gold: #C9A84C;
  --gold-light: #E2C97A;
  --gold-pale: #F0DFA0;
  --cream: #F5F0E6;
  --cream-warm: #EDE5D4;
  --cream-dark: #D4C9B0;
  --text-dark: #1C1C1A;
  --text-mid: #3D3D38;
  --text-muted: #7A7568;
  --white: #FDFAF4;
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'Jost', sans-serif;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--sans);
  background: var(--cream);
  color: var(--text-dark);
  line-height: 1.6;
  overflow-x: hidden;
}

/* NAVIGATION */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 4rem;
  background: rgba(27, 58, 39, 0.97);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(201,168,76,0.2);
}

.nav-logo {
  font-family: var(--serif);
  font-size: 1.5rem;
  font-weight: 500;
  color: var(--gold-light);
  letter-spacing: 0.01em;
  text-decoration: none;
}

.nav-logo span { color: var(--gold-pale); font-weight: 300; font-style: italic; }

.nav-links {
  display: flex;
  gap: 2.5rem;
  list-style: none;
}

.nav-links a {
  font-family: var(--sans);
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.75);
  text-decoration: none;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--gold-light); }

.nav-cta {
  background: var(--gold);
  color: var(--green-deep) !important;
  padding: 0.55rem 1.4rem;
  border-radius: 2px;
  font-weight: 600 !important;
  letter-spacing: 0.1em !important;
  transition: background 0.2s, transform 0.15s !important;
}

.nav-cta:hover { background: var(--gold-light) !important; transform: translateY(-1px); }

/* CONTENT SECTIONS */
section { padding: 6rem 4rem; }

.section-eyebrow {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.5rem;
}

.section-headline {
  font-family: var(--serif);
  font-size: 2.8rem;
  font-weight: 400;
  line-height: 1.1;
  color: var(--text-dark);
  margin-bottom: 1.5rem;
}

.section-headline em { font-style: italic; color: var(--green-light); }

.section-sub {
  font-size: 1rem;
  color: var(--text-mid);
  max-width: 45rem;
  line-height: 1.75;
}

/* AVAILABILITY TABLE */
.availability-section {
  background: var(--green-deep);
  color: var(--white);
}

.availability-section .section-headline { color: var(--white); }

.products-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 2rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(201,168,76,0.3);
}

.products-table th {
  padding: 1rem 1.5rem;
  text-align: left;
  font-weight: 600;
  font-size: 0.8rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-bottom: 2px solid var(--gold);
  color: var(--gold-light);
}

.products-table td {
  padding: 1rem 1.5rem;
  border-bottom: 1px solid rgba(201,168,76,0.2);
}

.products-table tr:last-child td {
  border-bottom: none;
}

.products-table tr:hover {
  background: rgba(201,168,76,0.08);
}

.product-name {
  font-weight: 500;
}

.product-category {
  display: inline-block;
  font-size: 0.75rem;
  background: rgba(201,168,76,0.2);
  color: var(--gold-pale);
  padding: 0.25rem 0.6rem;
  border-radius: 2px;
  margin-left: 0.5rem;
}

.status {
  font-size: 0.85rem;
  font-weight: 500;
}

.status.in-stock { color: #8BC34A; }
.status.limited { color: #FFC107; }

/* FORM STYLING */
.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 0.5rem;
  color: var(--text-mid);
}

.form-group input,
.form-group select {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid var(--cream-dark);
  border-radius: 2px;
  font-family: var(--sans);
  font-size: 0.95rem;
  color: var(--text-dark);
}

.form-group input:focus,
.form-group select:focus {
  outline: none;
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
}

button {
  background: var(--gold);
  color: var(--green-deep);
  padding: 0.75rem 2rem;
  border: none;
  border-radius: 2px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}

button:hover {
  background: var(--gold-light);
}

/* FOOTER */
footer {
  background: var(--green-deep);
  color: var(--white);
  padding: 3rem 4rem;
  text-align: center;
  margin-top: 4rem;
  border-top: 1px solid rgba(201,168,76,0.2);
}

footer p {
  font-size: 0.9rem;
  opacity: 0.8;
}

.admin-btn {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  background: var(--green-deep);
  color: var(--gold);
  padding: 0.6rem 1.2rem;
  border-radius: 2px;
  text-decoration: none;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  border: 1px solid var(--gold);
  transition: all 0.2s;
  z-index: 50;
}

.admin-btn:hover {
  background: var(--gold);
  color: var(--green-deep);
}
</style>
</head>
<body>

<!-- Navigation -->
<nav>
  <a href="#" class="nav-logo">HighPeak Harvest <span>— Glossop</span></a>
  <ul class="nav-links">
    <li><a href="#products">Produce</a></li>
    <li><a href="#availability">Weekly List</a></li>
    <li><a href="#signup">Get the List</a></li>
  </ul>
  <a href="#signup" class="nav-cta">Request a sample</a>
</nav>

<!-- Availability Section -->
<section id="availability" class="availability-section">
  <div style="max-width: 100%;">
    <p class="section-eyebrow">This week</p>
    <h2 class="section-headline">What's <em>available</em> right now</h2>
    <p class="section-sub">Updated every Monday. Trade accounts receive this list automatically — with pack sizes and pricing — every week.</p>
    
    <table class="products-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Pack sizes</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <span class="product-name"><%= product.name %></span>
              <span class="product-category"><%= product.category %></span>
            </td>
            <td><%= product.pack_sizes %></td>
            <td><span class="status <%= product.status === 'In stock' ? 'in-stock' : 'limited' %>"><%= product.status %></span></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

<!-- Signup Form Section -->
<section id="signup">
  <div style="max-width: 40rem;">
    <p class="section-eyebrow">Trade accounts</p>
    <h3 class="section-headline">Get the <em>weekly list</em></h3>
    <p class="section-sub">We'll send you this week's availability with pack sizes and trade pricing — every Monday morning, without fail.</p>
    
    <form id="enquiry-form" style="margin-top: 2rem;">
      <div class="form-group">
        <label>Your name</label>
        <input type="text" name="name" placeholder="Jane Smith" required>
      </div>
      
      <div class="form-group">
        <label>Business name</label>
        <input type="text" name="business_name" placeholder="The Black Dog, Glossop" required>
      </div>
      
      <div class="form-group">
        <label>Email address</label>
        <input type="email" name="email" placeholder="jane@restaurant.co.uk" required>
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label>Business type</label>
          <select name="business_type" required>
            <option value="">Select…</option>
            <option value="Restaurant">Restaurant</option>
            <option value="Café / Coffee shop">Café / Coffee shop</option>
            <option value="Greengrocer / Farm shop">Greengrocer / Farm shop</option>
            <option value="Pub / Bar">Pub / Bar</option>
            <option value="Hotel / Hospitality">Hotel / Hospitality</option>
            <option value="Other trade">Other trade</option>
          </select>
        </div>
        
        <div class="form-group">
          <label>Town / area</label>
          <input type="text" name="town" placeholder="Glossop" required>
        </div>
      </div>
      
      <button type="submit">Send me the list</button>
      <p style="margin-top: 1rem; text-align: center; color: var(--text-muted);">
        or <a href="https://wa.me/447700000000?text=Hi%20High%20Peak%20Harvest%20—%20I'd%20like%20to%20get%20the%20weekly%20trade%20list!" style="color: var(--gold); text-decoration: none;">Get this week's list on WhatsApp</a>
      </p>
    </form>
  </div>
</section>

<!-- Footer -->
<footer>
  <p>© 2025 High Peak Harvest. All rights reserved. Locally grown in Glossop, Derbyshire.</p>
  <p style="margin-top: 1rem;"><a href="/admin/login" style="color: var(--gold); text-decoration: none;">Admin Dashboard</a></p>
</footer>

<script>
document.getElementById('enquiry-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(e.target);
  const data = Object.fromEntries(formData);
  
  try {
    const response = await fetch('/submit-enquiry', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    
    if (response.ok) {
      alert('✓ Enquiry submitted! We'll be in touch soon.');
      e.target.reset();
    } else {
      alert('Failed to submit enquiry. Please try again.');
    }
  } catch (error) {
    alert('Error submitting form. Please try again.');
  }
});
</script>
</body>
</html>
